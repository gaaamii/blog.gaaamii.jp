{
  "version": 3,
  "pages404": true,
  "appType": "pages",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/feed",
        "destination": "/api/feed",
        "regex": "^/feed(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/mock/admin/posts/[id]",
      "regex": "^/api/mock/admin/posts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/mock/admin/posts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/mock/posts/[id]",
      "regex": "^/api/mock/posts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/mock/posts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/posts/[id]",
      "regex": "^/posts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/posts/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/404",
      "regex": "^/404(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/404(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/api/feed",
      "regex": "^/api/feed(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/feed(?:/)?$"
    },
    {
      "page": "/api/mock/admin/posts",
      "regex": "^/api/mock/admin/posts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/mock/admin/posts(?:/)?$"
    },
    {
      "page": "/api/mock/posts",
      "regex": "^/api/mock/posts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/mock/posts(?:/)?$"
    },
    {
      "page": "/api/revalidate",
      "regex": "^/api/revalidate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/revalidate(?:/)?$"
    }
  ],
  "dataRoutes": [
    {
      "page": "/",
      "dataRouteRegex": "^/_next/data/\\-Xwvo9RwRsTLirFoMPe2J/index\\.json$"
    },
    {
      "page": "/posts/[id]",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "dataRouteRegex": "^/_next/data/\\-Xwvo9RwRsTLirFoMPe2J/posts/([^/]+?)\\.json$",
      "namedDataRouteRegex": "^/_next/data/\\-Xwvo9RwRsTLirFoMPe2J/posts/(?<nxtPid>[^/]+?)\\.json$"
    }
  ],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}