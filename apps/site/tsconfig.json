{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@gaaamii/domain/*": ["../../packages/domain/*"],
      "@gaaamii/utils/*": ["../../packages/utils/*"],
      "@gaaamii/ui/*": ["../../packages/ui/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.astro",
    "../../packages/**/*.ts",
    "../../packages/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
