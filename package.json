{
  "name": "blog-gx-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "yarn workspace @apps/web dev",
    "dev:admin": "yarn workspace @apps/admin dev",
    "build:web": "yarn workspace @apps/web build",
    "build:admin": "yarn workspace @apps/admin build",
    "lint": "yarn workspaces foreach -pt run lint"
  }
}
